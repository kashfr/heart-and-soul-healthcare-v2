rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function incomingData() {
      return request.resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Reads the caller's users/{uid} doc to check their role.
    // Adds one document read per rule evaluation; will be replaced with
    // custom claims on the ID token once the Admin SDK invite flow lands.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasActiveProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function isAdmin() {
      return hasActiveProfile() && getRole() == 'admin';
    }

    function isStaff() {
      return hasActiveProfile() && (getRole() == 'admin' || getRole() == 'supervisor');
    }

    function isNurse() {
      return hasActiveProfile() && getRole() == 'nurse';
    }

    // --- Collections ---

    // Contact Submissions — public create, everything else via Admin SDK
    match /contactSubmissions/{submissionId} {
      allow read, update, delete: if false;
      allow create: if
        incomingData().name is string && incomingData().name.size() > 0 &&
        incomingData().email is string && incomingData().email.size() > 0 &&
        incomingData().subject is string && incomingData().subject.size() > 0 &&
        incomingData().message is string && incomingData().message.size() > 0 &&
        incomingData().status == 'new' &&
        incomingData().submittedAt == request.time &&
        (incomingData().get('phone', '') is string);
    }

    // Referral Submissions — public create, everything else via Admin SDK
    match /referralSubmissions/{submissionId} {
      allow read, update, delete: if false;
      allow create: if
        incomingData().client is map &&
        incomingData().program is map &&
        incomingData().referrer is map &&
        incomingData().details is map &&
        incomingData().client.firstName is string && incomingData().client.firstName.size() > 0 &&
        incomingData().client.lastName is string && incomingData().client.lastName.size() > 0 &&
        incomingData().client.dob is string &&
        incomingData().client.phone is string &&
        incomingData().status == 'new' &&
        incomingData().submittedAt == request.time;
    }

    // Patient Roster (directory fields: name, dob, diagnosis, address,
    // record #, requiresMar flag).
    // The /progress-note form is authenticated (AuthGuard), so reads only need
    // to be open to signed-in users — never the public. Nurses load the full
    // roster for the form's autofill picker, so read stays at isSignedIn()
    // rather than isStaff(); a whole-collection query would otherwise fail for
    // a nurse the moment one doc is unreadable. Writes are staff-only.
    // Sensitive clinical PHI (sex, allergies, attending physician, diet) does
    // NOT live here — it's in the care-team-gated /clinical sub-record below.
    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow create: if isStaff() &&
        incomingData().name is string && incomingData().name.size() > 0 &&
        incomingData().dob is string && incomingData().dob.size() > 0 &&
        incomingData().createdAt == request.time;
      allow update: if isStaff() &&
        incomingData().name is string && incomingData().name.size() > 0 &&
        incomingData().dob is string && incomingData().dob.size() > 0;
      allow delete: if isStaff();

      // Sensitive clinical profile — single doc at clinical/profile.
      // Holds sex, allergies, attending physician name/phone, and diet /
      // special instructions for the MAR header. Read is scoped to staff OR a
      // nurse on this patient's care team (assignedNurseIds), mirroring the
      // progressNotes care-team read so a nurse can only see clinical PHI for
      // clients she's actually assigned to. Writes are staff-only (managed from
      // the admin Patients screen).
      match /clinical/{clinicalId} {
        allow read: if isStaff()
          || (isNurse()
              && get(/databases/$(database)/documents/patients/$(patientId))
                   .data.get('assignedNurseIds', []).hasAny([request.auth.uid]));
        allow write: if isStaff();
      }
    }

    // Auto-assigned record-number counter (counters/patients). Staff-only:
    // patient creation, which consumes the counter inside a transaction, is
    // already staff-gated. Numbers only ever increment (never reused).
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }

    // MAR — standing medication orders (the regimen for a client's Medication
    // Administration Record). One doc per medication per client, linked by
    // patientId. Built/maintained by admin+supervisor (isStaff); a nurse on the
    // client's care team can READ the orders so she can document administrations
    // against them (Phase 3), mirroring the progressNotes care-team read.
    // Orders are never lossily mutated — a dose change is a discontinue (status
    // + endDate) plus a new order — so create pins createdBy/At and update
    // pins patientId/createdBy/createdAt to their original values.
    match /marOrders/{orderId} {
      allow read: if isStaff()
        || (isNurse()
            && resource.data.get('patientId', null) != null
            && get(/databases/$(database)/documents/patients/$(resource.data.patientId))
                 .data.get('assignedNurseIds', []).hasAny([request.auth.uid]));
      allow create: if isStaff()
        && incomingData().patientId is string && incomingData().patientId.size() > 0
        && incomingData().createdBy == request.auth.uid
        && incomingData().createdAt == request.time
        && incomingData().status == 'active';
      allow update: if isStaff()
        && incomingData().patientId == resource.data.patientId
        && incomingData().get('createdBy', null) == resource.data.get('createdBy', null)
        && incomingData().get('createdAt', null) == resource.data.get('createdAt', null);
      allow delete: if isStaff();
    }

    // MAR — administration events (append-only). One doc per dose a nurse
    // records as given/held/refused against an order. The compliance backbone:
    // entries can NEVER be edited or deleted, so a correction is a new entry.
    // Create is allowed for staff OR an active RN/LPN (the clinical credential
    // that may document administrations — CNA/HHA are structurally blocked),
    // with documentedBy pinned to the caller and at == request.time so a
    // view-as session can't forge authorship. Read is scoped to staff, the
    // documenter, or a nurse on the client's care team.
    match /marAdministrations/{adminId} {
      allow read: if isStaff()
        || (isNurse() && resource.data.get('documentedBy', null) == request.auth.uid)
        || (isNurse()
            && resource.data.get('patientId', null) != null
            && get(/databases/$(database)/documents/patients/$(resource.data.patientId))
                 .data.get('assignedNurseIds', []).hasAny([request.auth.uid]));
      allow create: if (isStaff()
            || (hasActiveProfile()
                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('credential', '') in ['RN', 'LPN']))
        && incomingData().documentedBy == request.auth.uid
        && incomingData().at == request.time
        && incomingData().patientId is string && incomingData().patientId.size() > 0
        && incomingData().status in ['given', 'held', 'refused'];
      allow update, delete: if false;
    }

    // MAR — medication-change records (add / change / discontinue). A nurse
    // (RN/LPN, in scope) STAGES a change on her note (status 'staged'); it takes
    // no effect until she submits, when an Admin SDK route APPLIES it (creates/
    // discontinues the order) and flags it for RN review. There is no approval
    // gate. Create is allowed for staff OR an active RN/LPN, with performedBy
    // pinned and status forced to 'staged'. A nurse may DELETE her own change
    // while it is still 'staged' (e.g. she removes it before submitting). Apply
    // and review are server-only (Admin SDK), so client updates are denied and
    // a delete is only allowed on a still-staged record.
    match /marChangeRequests/{reqId} {
      allow read: if isStaff()
        || (isNurse() && resource.data.get('performedBy', null) == request.auth.uid);
      allow create: if (isStaff()
            || (hasActiveProfile()
                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('credential', '') in ['RN', 'LPN']))
        && incomingData().performedBy == request.auth.uid
        && incomingData().stagedAt == request.time
        && incomingData().status == 'staged'
        && incomingData().patientId is string && incomingData().patientId.size() > 0
        && incomingData().sourceNoteId is string && incomingData().sourceNoteId.size() > 0
        && incomingData().type in ['add', 'change', 'discontinue'];
      allow delete: if resource.data.get('status', '') == 'staged'
        && (isStaff() || resource.data.get('performedBy', null) == request.auth.uid);
      allow update: if false;
    }

    // Progress Notes (PHI)
    // Create requires auth (form is gated). nurseId, if supplied, must match
    // the caller's uid so a signed-in user can't submit as someone else.
    // Read: staff see everything; a nurse sees only notes with her nurseId.
    // Update: staff anywhere; a nurse on her own notes only, and she cannot
    //   change nurseId or submittedAt (those are locked to the original).
    // Delete stays staff-only; nurses never delete.
    match /progressNotes/{noteId} {
      allow create: if hasActiveProfile()
        && incomingData().submittedAt == request.time
        && incomingData().status == 'submitted'
        && (!('nurseId' in incomingData()) || incomingData().nurseId == request.auth.uid);
      // Care-team read: a nurse can also read a note when she's on the
      // assignedNurseIds list of the patient that note is linked to
      // (patientId field, populated by Phase 1 backfill + the form's
      // roster-picker + the maintenance link flow). The get() pattern
      // matches getRole() above. Notes with no patientId (free-text
      // entries that didn't match the roster) stay author-only —
      // they never resolve a patient doc to check.
      //
      // First clause is the bug fix: the submit flow's idempotency precheck
      // (submissionExists → getDoc(progressNotes/<fresh-id>)) reads a doc that
      // does NOT exist yet. For a non-existent doc `resource` is null, so the
      // nurse clauses below — which dereference resource.data — ERROR and the
      // read is denied, throwing "Failed to submit progress note" before the
      // create ever runs. That silently blocked every nurse submission. Allow
      // any active user to read a non-existent note (it holds no data to leak)
      // so the precheck resolves cleanly; staff already short-circuit via
      // isStaff(). Same non-existent-doc hazard the noteDrafts rule calls out.
      allow read: if (hasActiveProfile() && resource == null)
        || isStaff()
        || (isNurse() && resource.data.nurseId == request.auth.uid)
        || (isNurse()
            && resource.data.get('patientId', null) != null
            && get(/databases/$(database)/documents/patients/$(resource.data.patientId))
                 .data.get('assignedNurseIds', []).hasAny([request.auth.uid]));
      // A nurse may toggle her personal archive fields (nurseArchivedAt/By)
      // but must never touch the staff-scope archive fields (archivedAt/By).
      // Co-signature fields (cosignedAt/By/ByName/Credential/Signature) are
      // off-limits to every client — only the Admin SDK route at
      // /api/admin/submissions/[id]/cosign writes them, since the credential
      // + self-author checks are cleanest server-side. We pin every cosign
      // field to its prior value (default null) so staff edits via the
      // submissions view can't quietly forge a co-sign.
      // Using get('field', null) so the rule works whether the field exists
      // yet or not.
      allow update: if (isStaff()
            && incomingData().get('cosignedAt', null) == resource.data.get('cosignedAt', null)
            && incomingData().get('cosignedBy', null) == resource.data.get('cosignedBy', null)
            && incomingData().get('cosignedByName', null) == resource.data.get('cosignedByName', null)
            && incomingData().get('cosignedCredential', null) == resource.data.get('cosignedCredential', null)
            && incomingData().get('cosignedSignature', null) == resource.data.get('cosignedSignature', null))
        || (isNurse()
            && resource.data.nurseId == request.auth.uid
            && incomingData().nurseId == resource.data.nurseId
            && incomingData().submittedAt == resource.data.submittedAt
            && incomingData().get('archivedAt', null) == resource.data.get('archivedAt', null)
            && incomingData().get('archivedBy', null) == resource.data.get('archivedBy', null)
            && incomingData().get('cosignedAt', null) == resource.data.get('cosignedAt', null)
            && incomingData().get('cosignedBy', null) == resource.data.get('cosignedBy', null)
            && incomingData().get('cosignedByName', null) == resource.data.get('cosignedByName', null)
            && incomingData().get('cosignedCredential', null) == resource.data.get('cosignedCredential', null)
            && incomingData().get('cosignedSignature', null) == resource.data.get('cosignedSignature', null));
      // Delete is admin-only and flows exclusively through the Admin SDK
      // route (/api/admin/submissions/[id] DELETE), which snapshots the note
      // into deletedNotes first. Deny all client-side deletes — even staff —
      // so the audit trail can never be bypassed.
      allow delete: if false;

      // Edit history — append-only audit trail for every update.
      // Create: staff or the note's owning nurse. Entry's editedBy must
      // match the caller, editedAt is request.time, and changes must be a map.
      // Read: staff (admin/supervisor) for any note; a nurse for her OWN notes
      // only, so she can see her own corrections logged but never another
      // nurse's history.
      // Update/delete: denied for everyone, including via Admin SDK console
      // edits (those bypass rules anyway — that's fine, we trust admins).
      match /editHistory/{entryId} {
        allow create: if (isStaff()
              || (isNurse() && get(/databases/$(database)/documents/progressNotes/$(noteId)).data.nurseId == request.auth.uid))
            && incomingData().editedBy == request.auth.uid
            && incomingData().editedAt == request.time
            && incomingData().changes is map;
        allow read: if isStaff()
            || (isNurse()
                && get(/databases/$(database)/documents/progressNotes/$(noteId)).data.nurseId == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // Progress Note Drafts — work-in-progress notes, autosaved.
    // Keyed by the authoring user's uid so there's exactly one active draft
    // per user. Staff can read drafts for visibility; writes are owner-only.
    // Read/delete use draftId (== owner uid) rather than resource.data so the
    // rule evaluates cleanly even when the document doesn't yet exist.
    match /noteDrafts/{draftId} {
      allow create, update: if isSignedIn()
        && request.auth.uid == draftId
        && incomingData().nurseId == request.auth.uid;
      allow read, delete: if isSignedIn()
        && (request.auth.uid == draftId || isStaff());
    }

    // Staff profiles (role lookup)
    // A signed-in user can always read their own profile so the client can
    // determine their role. Admins + supervisors can read all profiles (they
    // both manage staff via /admin/users). Writes flow through the Admin SDK
    // so the server can enforce the finer-grained "supervisor cannot touch
    // admin" rules.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow write: if false;
    }

    // Batch export audit trail
    // Signed-in staff write audit entries for their own exports; admins can
    // review all audit entries. Nothing is ever updated or deleted from the
    // client — the audit log is append-only by design.
    match /exportAudits/{auditId} {
      allow create: if isStaff()
        && incomingData().userId == request.auth.uid
        && incomingData().exportedAt == request.time
        && incomingData().submissionIds is list
        && incomingData().format in ['zip', 'merged-pdf'];
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Deleted-note audit trail. When an admin deletes a progress note, the
    // Admin SDK route snapshots the full note here before removing it. Admin
    // can read these for forensic recovery; all client writes are denied
    // (the snapshot is written server-side via Admin SDK, which bypasses
    // these rules).
    match /deletedNotes/{noteId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Org-wide settings (single doc at settings/global). Any signed-in
    // user can read so the client SettingsProvider can hydrate. Writes
    // go through the admin-gated /api/admin/settings PUT route, which
    // uses Admin SDK and therefore bypasses these rules — so we deny
    // direct client writes here.
    match /settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Audit trail of admin "View as" (read-only impersonation) sessions.
    // Written only via the Admin SDK (server route, which bypasses rules);
    // readable by admins for oversight; never client-writable or mutable.
    match /viewAsLog/{entryId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Client documents — METADATA for uploaded files (plans of care, initial
    // assessments, supervisory visit forms, physician orders, scans). The files
    // themselves live in Cloud Storage under patients/{patientId}/documents/
    // (see storage.rules, which mirrors this scoping). Staff and the client's
    // assigned nurses can read and upload; only staff can archive (soft delete);
    // documents are NEVER hard-deleted — the compliance record is append-only.
    // Create pins the uploader identity and the storagePath to THIS doc's id
    // under THIS patient, so metadata can't point at another client's file.
    match /patientDocuments/{docId} {
      allow read: if isStaff()
        || (isNurse()
            && resource.data.get('patientId', null) != null
            && get(/databases/$(database)/documents/patients/$(resource.data.patientId))
                 .data.get('assignedNurseIds', []).hasAny([request.auth.uid]));
      allow create: if (isStaff()
            || (isNurse()
                && get(/databases/$(database)/documents/patients/$(incomingData().patientId))
                     .data.get('assignedNurseIds', []).hasAny([request.auth.uid])))
        && incomingData().patientId is string && incomingData().patientId.size() > 0
        && incomingData().uploadedBy == request.auth.uid
        && incomingData().uploadedAt == request.time
        && incomingData().archived == false
        && incomingData().category is string && incomingData().category.size() > 0
        && incomingData().fileName is string && incomingData().fileName.size() > 0
        // Keep metadata contentType honest (defense in depth: the viewer also
        // renders only from the storage object's rules-enforced type, so a
        // forged text/html here could never execute in the app origin).
        && incomingData().contentType in [
             'application/pdf', 'image/jpeg', 'image/png', 'image/heic',
             'application/msword',
             'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
           ]
        && incomingData().storagePath ==
             'patients/' + incomingData().patientId + '/documents/' + docId + '/' + incomingData().fileName;
      // Staff may archive/restore and fix labeling; identity, file pointer,
      // and ownership fields are immutable.
      allow update: if isStaff()
        && incomingData().diff(resource.data).affectedKeys()
             .hasOnly(['archived', 'archivedBy', 'archivedByName', 'archivedAt', 'title', 'category', 'docDate']);
      allow delete: if false;
    }

    // Scheduled client visits (shift + RN supervisory). The day-to-day schedule
    // is maintained by admin + supervisors only; the care team (assigned
    // nurses) can READ it for the dashboard's Upcoming visits. Visits are never
    // deleted — cancellation is a status change, so the schedule keeps its
    // history. Create pins the author and starts life 'scheduled'; updates
    // can't rewrite ownership or move the visit to another client.
    match /patientVisits/{visitId} {
      allow read: if isStaff()
        || (isNurse()
            && resource.data.get('patientId', null) != null
            && get(/databases/$(database)/documents/patients/$(resource.data.patientId))
                 .data.get('assignedNurseIds', []).hasAny([request.auth.uid]));
      allow create: if isStaff()
        && incomingData().patientId is string && incomingData().patientId.size() > 0
        && incomingData().date is string && incomingData().date.size() == 10
        && incomingData().type in ['shift', 'supervisory']
        && incomingData().status == 'scheduled'
        && incomingData().createdBy == request.auth.uid
        && incomingData().createdAt == request.time;
      allow update: if isStaff()
        && incomingData().patientId == resource.data.patientId
        && incomingData().get('createdBy', null) == resource.data.get('createdBy', null)
        && incomingData().get('createdAt', null) == resource.data.get('createdAt', null)
        && incomingData().get('status', '') in ['scheduled', 'completed', 'cancelled'];
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
